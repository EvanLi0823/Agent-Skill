{
  "mcpServers": {
    "unityMCP": {
      "command": "uvx",
      "args": ["--from", "mcpforunityserver", "mcp-for-unity", "--transport", "stdio"]
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp",
      "description": "Notion MCP服务器",
      "disabled": true
    },
    "cocos-mcp-server": {
      "type": "http",
      "url": "http://localhost:8088/mcp",
      "description": "Cocos Creator MCP服务器",
      "disabled": true
    },
    "localhost": {
      "type": "http",
      "url": "http://localhost:3000/mcp",
      "description": "本地开发MCP服务器",
      "disabled": true
    }
  }
}
